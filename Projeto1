import tkinter as tk
from tkinter import ttk, messagebox
import threading
import time

class BrincadeiraCriancasApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Simulador: Brincadeira de Crianças")
        self.root.geometry("900x750")

        # --- VARIÁVEIS DE CONCORRÊNCIA (SINCRONIZAÇÃO) ---
        self.K = 0  # Capacidade máxima do cesto
        self.bolas_no_cesto = 0 # Contador atual de bolas
        self.mutex_cesto = threading.Lock()  # Mutex para garantir que apenas uma thread altere o contador por vez
        self.sem_bolas = None    # Semáforo para contar bolas disponíveis (impede pegar de cesto vazio)
        self.sem_espacos = None  # Semáforo para contar espaços vazios (impede colocar em cesto cheio)
        
        self.threads_criancas = [] # Lista para gerenciar as threads criadas
        
        # --- ESTRUTURAS VISUAIS ---
        self.desenhos_criancas = {} # Dicionário para guardar as referências gráficas de cada criança
        self.desenho_cesto_texto = None
        self.total_criancas_criadas = 0

        # Definição das posições horizontais (colunas) para a animação
        self.COL_ESPERANDO = 150
        self.COL_BRINCANDO = 425
        self.COL_DESCANSANDO = 700

        self._construir_interface()

    def _construir_interface(self):
        """Cria os elementos visuais da janela principal."""
        # Painel Superior: Configuração do Cesto
        frame_cesto = tk.LabelFrame(self.root, text="Configuração do Cesto", padx=10, pady=5)
        frame_cesto.pack(fill="x", padx=10, pady=5)

        tk.Label(frame_cesto, text="Capacidade (K):").grid(row=0, column=0, padx=5)
        self.entry_k = tk.Entry(frame_cesto, width=10)
        self.entry_k.grid(row=0, column=1, padx=5)
        
        self.btn_criar_cesto = tk.Button(frame_cesto, text="Inicializar Cesto", command=self.inicializar_cesto)
        self.btn_criar_cesto.grid(row=0, column=2, padx=10)

        # Painel Médio: Criação de novas crianças
        frame_crianca = tk.LabelFrame(self.root, text="Adicionar Criança", padx=10, pady=5)
        frame_crianca.pack(fill="x", padx=10, pady=5)

        tk.Label(frame_crianca, text="ID:").grid(row=0, column=0, padx=5)
        self.entry_id = tk.Entry(frame_crianca, width=10)
        self.entry_id.grid(row=0, column=1, padx=5)

        self.var_tem_bola = tk.BooleanVar()
        tk.Checkbutton(frame_crianca, text="Nasce com Bola?", variable=self.var_tem_bola).grid(row=0, column=2, padx=5)

        tk.Label(frame_crianca, text="Tb (s):").grid(row=0, column=3, padx=5)
        self.entry_tb = tk.Entry(frame_crianca, width=5)
        self.entry_tb.grid(row=0, column=4, padx=5)

        tk.Label(frame_crianca, text="Td (s):").grid(row=0, column=5, padx=5)
        self.entry_td = tk.Entry(frame_crianca, width=5)
        self.entry_td.grid(row=0, column=6, padx=5)

        self.btn_add_crianca = tk.Button(frame_crianca, text="Criar Criança", command=self.criar_crianca, state=tk.DISABLED)
        self.btn_add_crianca.grid(row=0, column=7, padx=10)

        # Painel de Simulação Gráfica (Canvas)
        frame_visual = tk.LabelFrame(self.root, text="Simulação em Tempo Real", padx=10, pady=5)
        frame_visual.pack(fill="both", expand=True, padx=10, pady=5)

        scroll_y = tk.Scrollbar(frame_visual)
        scroll_y.pack(side="right", fill="y")
        
        self.canvas = tk.Canvas(frame_visual, bg="white", height=300, yscrollcommand=scroll_y.set)
        self.canvas.pack(fill="both", expand=True)
        scroll_y.config(command=self.canvas.yview)

        self._desenhar_cenario_base()

        # Painel Inferior: Tabela de Logs e Status
        frame_tabela = tk.LabelFrame(self.root, text="Logs de Status das Crianças", padx=10, pady=5)
        frame_tabela.pack(fill="both", expand=True, padx=10, pady=5)

        colunas = ("ID", "Tb", "Td", "Status")
        self.tabela = ttk.Treeview(frame_tabela, columns=colunas, show="headings", height=5)
        self.tabela.heading("ID", text="Identificador")
        self.tabela.heading("Tb", text="T. Brincar (s)")
        self.tabela.heading("Td", text="T. Descanso (s)")
        self.tabela.heading("Status", text="Status Atual")
        
        self.tabela.column("ID", width=100, anchor="center")
        self.tabela.column("Tb", width=100, anchor="center")
        self.tabela.column("Td", width=100, anchor="center")
        self.tabela.column("Status", width=400)
        self.tabela.pack(fill="both", expand=True)

    def _desenhar_cenario_base(self):
        """Desenha o fundo colorido das 3 áreas no canvas."""
        self.canvas.create_rectangle(20, 50, 280, 2000, fill="#FFF3E0", outline="") # Fila
        self.canvas.create_rectangle(300, 50, 550, 2000, fill="#E8F5E9", outline="") # Brincando
        self.canvas.create_rectangle(570, 50, 820, 2000, fill="#E3F2FD", outline="") # Descanso

        # Nomes das colunas
        self.canvas.create_text(self.COL_ESPERANDO, 30, text="FILA / CESTO", font=("Arial", 12, "bold"), fill="#E65100")
        self.canvas.create_text(self.COL_BRINCANDO, 30, text="ÁREA DE BRINCADEIRA", font=("Arial", 12, "bold"), fill="#1B5E20")
        self.canvas.create_text(self.COL_DESCANSANDO, 30, text="ÁREA DE DESCANSO", font=("Arial", 12, "bold"), fill="#0D47A1")

        # Representação visual do Cesto (retângulo)
        self.canvas.create_rectangle(20, 60, 280, 100, fill="#FFCC80", outline="black", width=2)
        self.desenho_cesto_texto = self.canvas.create_text(self.COL_ESPERANDO, 80, text="Cesto não inicializado", font=("Arial", 11, "bold"))

    def inicializar_cesto(self):
        """Define a capacidade K e inicializa os semáforos."""
        try:
            self.K = int(self.entry_k.get())
            if self.K <= 0: raise ValueError
        except ValueError:
            messagebox.showerror("Erro", "K deve ser um inteiro > 0.")
            return

        # sem_bolas: inicia em 0 (ninguém pega bola se o cesto começa vazio)
        self.sem_bolas = threading.Semaphore(0)
        # sem_espacos: inicia em K (temos K vagas livres para colocar bolas)
        self.sem_espacos = threading.Semaphore(self.K)

        self.btn_criar_cesto.config(state=tk.DISABLED)
        self.entry_k.config(state=tk.DISABLED)
        self.btn_add_crianca.config(state=tk.NORMAL)
        self.atualizar_visual_cesto()

    def atualizar_visual_cesto(self):
        """Atualiza o texto da quantidade de bolas no cesto na interface."""
        texto = f"🧺 CESTO: {self.bolas_no_cesto} / {self.K} BOLAS"
        # after(0, ...) garante que a interface gráfica seja atualizada pela thread principal
        self.root.after(0, lambda: self.canvas.itemconfig(self.desenho_cesto_texto, text=texto))

    def criar_crianca(self):
        """Coleta os dados e lança uma nova thread para a criança."""
        nome_id = self.entry_id.get()
        tem_bola = self.var_tem_bola.get()
        try:
            tb = float(self.entry_tb.get())
            td = float(self.entry_td.get())
        except ValueError:
            messagebox.showerror("Erro", "Tb e Td devem ser números.")
            return

        # Verifica se o ID já existe
        if not nome_id or nome_id in self.desenhos_criancas:
            messagebox.showerror("Erro", "ID inválido ou já existe.")
            return

        # Lógica para posicionar cada criança em uma linha vertical diferente (raia)
        y_crianca = 150 + (self.total_criancas_criadas * 70)
        self.total_criancas_criadas += 1
        self.canvas.config(scrollregion=(0, 0, 850, max(400, y_crianca + 100)))

        # Desenha a criança (círculo e ícone) fora da tela inicialmente
        raio = 20
        x_inicial = -100 
        id_icone = self.canvas.create_text(x_inicial, y_crianca - 25, text="", font=("Segoe UI Emoji", 14))
        id_oval = self.canvas.create_oval(x_inicial-raio, y_crianca-raio, x_inicial+raio, y_crianca+raio, fill="gray")
        id_texto = self.canvas.create_text(x_inicial, y_crianca + 30, text=nome_id, font=("Arial", 10, "bold"))
        
        self.desenhos_criancas[nome_id] = {"oval": id_oval, "texto": id_texto, "icone": id_icone, "y": y_crianca}

        # Insere dados na tabela de log
        self.tabela.insert("", tk.END, iid=nome_id, values=(nome_id, tb, td, "Iniciando..."))

        # INICIALIZAÇÃO DA THREAD DA CRIANÇA
        t = threading.Thread(target=self.rotina_crianca, args=(nome_id, tem_bola, tb, td), daemon=True)
        self.threads_criancas.append(t)
        t.start()

    def atualizar_status(self, id_crianca, status_texto, cor_visual, icone, pos_x):
        """Envia comandos para atualizar a UI para a thread principal."""
        self.root.after(0, self._aplicar_atualizacao_ui, id_crianca, status_texto, cor_visual, icone, pos_x)

    def _aplicar_atualizacao_ui(self, id_crianca, status_texto, cor, icone, pos_x):
        """Modifica efetivamente os elementos gráficos e a tabela."""
        valores = self.tabela.item(id_crianca, "values")
        self.tabela.item(id_crianca, values=(valores[0], valores[1], valores[2], status_texto))
        
        desenho = self.desenhos_criancas[id_crianca]
        y, raio = desenho["y"], 20
        
        # Atualiza cor e posição do círculo, ícone e nome da criança no canvas
        self.canvas.itemconfig(desenho["oval"], fill=cor)
        self.canvas.coords(desenho["oval"], pos_x - raio, y - raio, pos_x + raio, y + raio)
        self.canvas.itemconfig(desenho["icone"], text=icone)
        self.canvas.coords(desenho["icone"], pos_x, y - 25)
        self.canvas.coords(desenho["texto"], pos_x, y + 30)

    def passar_tempo_ativo(self, tempo_segundos):
        """
        Simula a atividade (brincar/descansar) sem usar time.sleep().
        Usa 'espera ocupada' para manter a thread ativa, conforme pedido no enunciado.
        """
        inicio = time.time()
        while (time.time() - inicio) < tempo_segundos:
            pass

    def rotina_crianca(self, id_crianca, tem_bola, tb, td):
        """Loop eterno que define o comportamento de cada thread 'Criança'."""
        while True:
            if tem_bola:
                # --- ESTADO: BRINCANDO ---
                self.atualizar_status(id_crianca, "⚽ Brincando", "#4CAF50", "⚽", self.COL_BRINCANDO)
                self.passar_tempo_ativo(tb)

                # --- ESTADO: COLOCAR BOLA NO CESTO ---
                self.atualizar_status(id_crianca, "⏳ Esperando espaço no cesto", "#FF9800", "⏳", self.COL_ESPERANDO)
                
                # P(sem_espacos): Se o cesto estiver cheio (0 espaços), a thread para aqui
                self.sem_espacos.acquire() 

                with self.mutex_cesto: # Garante exclusão mútua no acesso à variável compartilhada
                    self.bolas_no_cesto += 1
                    self.atualizar_visual_cesto()
                
                # V(sem_bolas): Avisa que há uma bola disponível para quem estiver esperando
                self.sem_bolas.release()
                tem_bola = False

                # --- ESTADO: DESCANSANDO ---
                self.atualizar_status(id_crianca, "💤 Descansando (Quieta)", "#2196F3", "💤", self.COL_DESCANSANDO)
                self.passar_tempo_ativo(td)

            else:
                # --- ESTADO: PEGAR BOLA DO CESTO ---
                self.atualizar_status(id_crianca, "⏳ Esperando bola no cesto", "#FF9800", "⏳", self.COL_ESPERANDO)
                
                # P(sem_bolas): Se o cesto estiver vazio (0 bolas), a thread para aqui
                self.sem_bolas.acquire() 

                with self.mutex_cesto: # Acesso seguro ao contador
                    self.bolas_no_cesto -= 1
                    self.atualizar_visual_cesto()
                
                # V(sem_espacos): Avisa que liberou um espaço no cesto
                self.sem_espacos.release()
                tem_bola = True

# Início da aplicação
if __name__ == "__main__":
    root = tk.Tk()
    app = BrincadeiraCriancasApp(root)
    root.mainloop()
